# App
APP_ENV=development
API_BASE_URL=http://localhost:8000
FRONTEND_ORIGIN=http://localhost:5173
MOCK_PROVIDERS=true
PERSISTENCE_BACKEND=memory
# --- User auth (enterprise registration + employee login) ---
# Require a signed-in user session for /api/*. Leave false for local demo mode.
AUTH_REQUIRED=false
# Secret for signing session JWTs. REQUIRED in production (otherwise sessions
# reset on every restart). Generate with: openssl rand -hex 32
AUTH_JWT_SECRET=
AUTH_TOKEN_TTL_HOURS=72

# Optional legacy shared-secret for service/script access to /api/*.
# Generate with: openssl rand -hex 32
API_AUTH_TOKEN=

# Supabase (only used when PERSISTENCE_BACKEND=supabase)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# Frontend (Vite bakes VITE_* values in at build time)
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:8000
# Must match API_AUTH_TOKEN when it is set.
VITE_API_AUTH_TOKEN=

# Redis
REDIS_URL=redis://localhost:6379/0

# Twilio WhatsApp
TWILIO_AUTH_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# LLM / Research / OCR
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
TAVILY_API_KEY=
PROSPEO_API_KEY=
PROSPEO_BASE_URL=https://api.prospeo.io
PROSPEO_ENRICH_MOBILE=false
PROSPEO_ONLY_VERIFIED_EMAIL=true
X_BEARER_TOKEN=
X_API_BASE_URL=https://api.x.com/2
GOOGLE_APPLICATION_CREDENTIALS=

# HubSpot (OAuth)
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:8001/api/crm/hubspot/callback
HUBSPOT_SCOPES="crm.objects.contacts.read crm.objects.contacts.write crm.objects.companies.read crm.objects.companies.write"
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
HUBSPOT_TOKEN_ENCRYPTION_KEY=
