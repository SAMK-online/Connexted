{
  "manifest_version": 3,
  "name": "CONNEXTed Post Capture",
  "version": "0.1.0",
  "description": "Send public social posts into CONNEXTed event folders.",
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Send to CONNEXTed",
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/connexted-title-logo.png"
    }
  },
  "icons": {
    "128": "icons/connexted-title-logo.png"
  }
}
